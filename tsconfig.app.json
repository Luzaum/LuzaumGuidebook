{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "vite-env.d.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "config/**/*.ts",
    "hooks/**/*.ts",
    "layouts/**/*.ts",
    "layouts/**/*.tsx",
    "lib/**/*.ts",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "services/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "temp",
    "tmp",
    ".claude/worktrees",
    "modules/**/node_modules",
    "src/modules/dados-veterinarios",
    "rx_print_page_tail.tsx",
    "scripts/**/*.py",
    "**/*.log"
  ]
}
