# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_CONSENSUS_BUCKET=consulta-consensos

# ReceituarioVET data source
# local (default): usa rxDb/rxStorage
# supabase: usa tabelas patients/tutors com clinic_id ativo + RLS
VITE_RX_DATA_SOURCE=local

# DeepSeek (optional - complementary AI opinion)
# NOTE: DeepSeek API official models are text/reasoning (no native image generation model).
DEEPSEEK_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_MODEL=deepseek-reasoner
VITE_DEEPSEEK_MODEL_STRATEGY=auto
VITE_DEEPSEEK_FALLBACK_MODEL=deepseek-chat
